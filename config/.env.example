# TradingView webhook shared secret
WEBHOOK_TOKEN=SECRETxxyyzz

# GMO Coin API credentials (margin account)
GMO_API_KEY=YOUR_API_KEY
GMO_API_SECRET=YOUR_API_SECRET

# Discord webhook URL for notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Maximum allowed timestamp skew in seconds
MAX_SKEW_SECONDS=60

# Quantity step for BTC_JPY contracts
QTY_STEP=0.01

# Idempotency window in seconds for alert deduplication
EVENT_TTL_SECONDS=600

# Optional: override FastAPI log level (INFO/DEBUG/WARNING)
LOG_LEVEL=INFO

# Optional: comma separated list of IPs allowed to call the webhook (empty disables check)
ALLOWED_SOURCE_IPS=

# Runtime environment label exposed by the API
ENV=production
